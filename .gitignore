test-data/generated/

# Cache directories
.cache/
*.cache

# ===================================
# SECURITY & SENSITIVE DATA
# ===================================

# Never commit these patterns
**/password*
**/secret*
**/token*
**/credentials*
**/.aws/
**/.ssh/

# JWT secrets
jwt-secret.txt
jwt.key

# Database credentials
database.properties
db-credentials.txt

# ===================================
# KEEP THESE FILES (NEGATION RULES)
# ===================================

# We want to keep these specific files
!.gitkeep
!.gitignore
!.editorconfig
!.prettierrc
!.eslintrc.json

# Keep documentation files
!README.md
!DOCUMENTATION*.md
!TESTING_GUIDE.txt
!*.md

# Keep SQL migration files (Flyway)
!backend/src/main/resources/db/migration/*.sql

# Keep test data SQL
!TEST_DATA_REFERRERS.sql

# Keep configuration templates
!**/application.yml.example
!.env.example

# ===================================
# END OF .gitignore
# ===================================

# NOTE:
# - Always review before committing
# - Never commit secrets or API keys
# - Use environment variables for sensitive data
# - Check twice before pushing to GitHub
